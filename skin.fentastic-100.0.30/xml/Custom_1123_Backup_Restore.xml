<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1123">
	<defaultcontrol always="true">9000</defaultcontrol>
	<include>Animation_DialogPopupOpenClose</include>
	<controls>
		<control type="group">
			<centerleft>50%</centerleft>
			<width>600</width>
			<centertop>60%</centertop>
			<height>700</height>
			<include content="DialogBackgroundCommons">
				<param name="width" value="600" />
				<param name="height" value="475" />
				<param name="header_label" value="Backup & Restore" />
				<param name="header_id" value="" />
				<param name="diffusetexture" value="masks/dialog-bg-squareish.png" />
			</include>
			<control type="panel" id="9000">
				<include>ButtonMenuList</include>
				<onback>Dialog.Close(1123)</onback>
				<onback>ActivateWindow(1106)</onback>
				<content>
					<item>
						<label>Backup Favourites</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>RunScript(script.fentastic.helper,mode=backup_favs)</onclick>
					</item>
					<item>
						<label>Restore Favourites</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>RunScript(script.fentastic.helper,mode=restore_favs)</onclick>
					</item>
					<item>
						<label>Backup GUI Settings</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>RunScript(script.fentastic.helper,mode=backup_gui)</onclick>
					</item>
					<item>
						<label>Restore GUI Settings</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>RunScript(script.fentastic.helper,mode=restore_gui)</onclick>
					</item>
					<item>
						<label>Restore Default GUI Settings</label>
						<onclick>Dialog.Close(all)</onclick>
						<onclick>RunScript(script.fentastic.helper,mode=restore_gui_dflt)</onclick>
					</item>
				</content>
			</control>
		</control>
	</controls>
</window>
