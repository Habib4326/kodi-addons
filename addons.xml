<?xml version="1.0" encoding="UTF-8"?>
<addons>

    <!-- ===== Repository Add-on ===== -->
    <addon id="repository.habib.addons"
           name="Habib Kodi Add-ons Repository"
           version="1.0.0"
           provider-name="Habib">

        <extension point="xbmc.addon.repository"
                   name="Habib Kodi Add-ons Repository">
            <dir>
                <info compressed="false">
                    https://habib4326.github.io/kodi-addons/addons.xml
                </info>
                <checksum>
                    https://habib4326.github.io/kodi-addons/addons.xml.md5
                </checksum>
                <datadir zip="true">
                    https://habib4326.github.io/kodi-addons/zips/
                </datadir>
            </dir>
        </extension>

        <extension point="xbmc.addon.metadata">
            <summary>Habib's Personal Kodi Repository</summary>
            <description>
                Install and update Kodi add-ons by Habib.
            </description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.jpg</fanart>
            </assets>
        </extension>
    </addon>

    <!-- ===== Addon 1: FTP Live ===== -->
    <addon id="plugin.video.Live"
           name="FTP Live"
           version="1.0.0"
           provider-name="Habib">

        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>

        <extension point="xbmc.python.pluginsource" library="default.py">
            <provides>video</provides>
        </extension>

        <extension point="xbmc.addon.metadata">
            <summary lang="en">Browse and stream movies from ICC FTP</summary>
            <description lang="en">
                Streams videos directly from ICC FTP server folder structure.
            </description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.jpg</fanart>
            </assets>
        </extension>
    </addon>

    <!-- ===== Addon 2: codexfinder ===== -->
    <addon id="plugin.video.codexfinder"
           name="ICC GitHub XML"
           version="1.0.0"
           provider-name="Habib">

        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>

        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>video</provides>
        </extension>

        <extension point="xbmc.addon.metadata">
            <summary>Watch movies from local FTP servers</summary>
            <description>
                Browse and play movies directly from your specified local IP servers.
            </description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.jpg</fanart>
            </assets>
        </extension>
    </addon>

</addons>